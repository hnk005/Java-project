<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox spacing="12" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.quanlykho.controller.ProductController"
      style="-fx-background-color: transparent;">

    <Label text="Quản lý Sản phẩm" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>

    <VBox spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
        <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
        </padding>

        <!-- Toolbar -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍 Tìm kiếm theo tên..." prefWidth="280"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Thêm mới" onAction="#onAdd"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-plus" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
            <Button text="Sửa" onAction="#onEdit"
                    style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-pencil" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
            <Button text="Xóa" onAction="#onDelete"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-delete" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
            <Button text="Làm mới" onAction="#onRefresh"
                    style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-refresh" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
        </HBox>

        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="240"/>
                <TableColumn fx:id="colCategory" text="Danh mục" prefWidth="150"/>
                <TableColumn fx:id="colQuantity" text="Số lượng" prefWidth="100"/>
                <TableColumn fx:id="colPrice" text="Giá bán" prefWidth="160"/>
                <TableColumn fx:id="colImage" text="Ảnh" prefWidth="160"/>
            </columns>
            <placeholder>
                <Label text="Không có dữ liệu"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>

