<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox spacing="12" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.quanlykho.controller.AccountController"
      style="-fx-background-color: transparent;">

    <Label text="Quản lý Tài khoản" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>

    <VBox spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 6, 0, 0, 2);">
        <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
        </padding>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍 Tìm theo tên đăng nhập / họ tên..." prefWidth="320"
                       style="-fx-background-radius: 5; -fx-border-radius: 5;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Thêm mới" onAction="#onAdd"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-account-plus" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
            <Button text="Sửa" onAction="#onEdit"
                    style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-pencil" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
            <Button fx:id="statusToggleBtn" onAction="#onToggleStatus"
                    style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon fx:id="statusIcon" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
            <Button text="Làm mới" onAction="#onRefresh"
                    style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16 7 16;">
                <graphic>
                    <FontIcon iconLiteral="mdi-refresh" iconSize="20" iconColor="white"/>
                </graphic>
            </Button>
        </HBox>

        <TableView fx:id="accountTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colUsername" text="Tên đăng nhập" prefWidth="180"/>
                <TableColumn fx:id="colFullName" text="Họ và tên" prefWidth="220"/>
                <TableColumn fx:id="colRole" text="Vai trò" prefWidth="150"/>
                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="Không có dữ liệu"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>

